# Backend API URL (include trailing slash)
VITE_BACKEND_URL=http://localhost:3000/

# Reown AppKit project ID (required for MetaMask / wallet connection)
VITE_PROJECT_ID=your_reown_project_id_here

# Deployed ChessterEscrow contract address on Somnia Testnet
# Players call createMatch/joinMatch with native STT value.
# Populated after: forge script script/DeployChessGame.s.sol --rpc-url $SOMNIA_RPC_URL --broadcast
VITE_ESCROW_CONTRACT_ADDRESS=0x

# Deployed ChessGame contract address on Somnia Testnet
# Used by the Reactivity SDK to subscribe to on-chain game events.
# Populated after: forge script script/DeployChessGame.s.sol --rpc-url $SOMNIA_RPC_URL --broadcast
VITE_CHESS_GAME_CONTRACT_ADDRESS=0x

# Somnia Testnet WebSocket RPC URL (for Reactivity SDK subscriptions)
VITE_SOMNIA_WS_URL=wss://dream-rpc.somnia.network/ws

