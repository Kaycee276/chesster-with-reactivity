# ── SQLite ───────────────────────────────────────────────────────────────────
# Optional: custom path for the SQLite database file (default: backend/chesster.db)
# SQLITE_DB_PATH=/path/to/chesster.db

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# Comma-separated list of allowed frontend origins (use * for dev only)
# Example: CORS_ORIGIN=https://chesster-lovat.vercel.app
CORS_ORIGIN=*

# ── Somnia Testnet ────────────────────────────────────────────────────────────
# HTTP RPC endpoint for Somnia Testnet (Shannon)
SOMNIA_RPC_URL=https://dream-rpc.somnia.network/

# Address of the deployed ChessGame contract on Somnia Testnet
# Populated after: forge script script/DeployChessGame.s.sol --rpc-url $SOMNIA_RPC_URL --broadcast
CHESS_GAME_CONTRACT_ADDRESS=0x

# Address of the deployed ChessterEscrow contract on Somnia Testnet
ESCROW_CONTRACT_ADDRESS=0x

# Private key of the coordinator wallet (submits moves/endGame to ChessGame contract)
# Fund this wallet with STT for gas. Chain ID: 50312.
# WARNING: keep this secret — never commit to git.
COORDINATOR_PRIVATE_KEY=0x
